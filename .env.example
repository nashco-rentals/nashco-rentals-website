# Quote request email delivery (Resend — https://resend.com)
# Free tier: 3,000 emails/month, 100/day. Sign up, create an API key,
# and paste it below. Restart the dev server after setting.
RESEND_API_KEY=

# Sender address. Until you verify rentnashco.com in Resend,
# leave this blank and the fallback "onboarding@resend.dev" is used.
# After domain verification, set to e.g.:
#   RESEND_FROM="NASHCO Rentals <quotes@rentnashco.com>"
RESEND_FROM=

# Where quote requests are emailed.
QUOTE_RECIPIENT=heath@rentnashco.com
